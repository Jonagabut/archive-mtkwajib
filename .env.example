# ==========================================
# MTK WAJIB ARCHIVE — Environment Variables
# Copy to .env.local and fill in values
# ==========================================

# Supabase Project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anonymous Key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (KEEP SECRET — server only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Class Passcode (single shared secret for write actions)
CLASS_PASSCODE=MTKWajib2026

# Spotify Playlist Embed ID (from playlist share link)
NEXT_PUBLIC_SPOTIFY_PLAYLIST_ID=YOUR_PLAYLIST_ID

# Time Capsule Unlock Date (ISO 8601)
NEXT_PUBLIC_CAPSULE_UNLOCK_DATE=2031-07-01T00:00:00.000Z

# App URL (for OG tags, sitemap, etc.)
NEXT_PUBLIC_APP_URL=https://mtk-wajib-archive.vercel.app
